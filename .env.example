# 应用
APP_ENV=development
SECRET_KEY=change-me-in-production

# PostgreSQL（Day 1 下午 docker compose 后启用）
DATABASE_URL=postgresql+asyncpg://fin:fin@localhost:5432/fin_agent

PGVECTOR_DATABASE_URL=postgresql://fin:fin@localhost:5432/fin_agent
LANGGRAPH_CHECKPOINT_URL=postgresql://fin:fin@localhost:5432/fin_agent?options=-csearch_path%3Druntime
EMBEDDING_DIM=1536

# Embedding（OpenAI 兼容接口）
# dashscope | xfyun
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v2
EMBEDDING_BASE_URL=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=

# 讯飞星辰 MaaS Embedding 示例（Qwen3-Embedding-8B）：
# EMBEDDING_PROVIDER=xfyun
# EMBEDDING_API_KEY=your_app_id:your_api_secret_b64
# EMBEDDING_MODEL=xop3qwen8bembedding
# EMBEDDING_BASE_URL=https://maas-api.cn-huabei-1.xf-yun.com/v2
# EMBEDDING_DIM=4096（讯飞 v2 支持 768/1024/2048/4096，不支持 1536）
# EMBEDDING_BATCH_SIZE=8（讯飞 gRPC 单次约 4MB，长文本需小 batch；0=按 provider 默认）
PGVECTOR_COLLECTION_FAQ=faq_md_vectors
PGVECTOR_COLLECTION_MACRO=fin_macro_vectors
PGVECTOR_COLLECTION_ANNUAL_REPORT=fin_annual_report_vectors
PGVECTOR_COLLECTION_RESEARCH_REPORT=fin_research_report_vectors
PGVECTOR_COLLECTION_INDUSTRY_WHITEPAPER=fin_industry_whitepaper_vectors
PGVECTOR_COLLECTION_POLICY=fin_policy_vectors

# Redis
REDIS_URL=redis://localhost:6379/0

# Elasticsearch（BM25 / 全文检索；docker compose up -d elasticsearch kibana）
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=fin_agent
ELASTICSEARCH_INDEX_FAQ=fin_agent_faq
ELASTICSEARCH_INDEX_MACRO=fin_agent_macro_research
ELASTICSEARCH_INDEX_ANNUAL_REPORT=fin_agent_annual_reports
ELASTICSEARCH_INDEX_RESEARCH_REPORT=fin_agent_research_reports
ELASTICSEARCH_INDEX_INDUSTRY_WHITEPAPER=fin_agent_industry_whitepapers
ELASTICSEARCH_INDEX_POLICY=fin_agent_policy
ELASTICSEARCH_ENABLED=false
# Kibana 可视化（Dev Tools / Index Management / Discover）
KIBANA_URL=http://localhost:5601

# Milvus（向量检索；建议先与 ES BM25 并存）
MILVUS_ENABLED=false
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION_PREFIX=fin_agent
MILVUS_COLLECTION_FAQ=fin_agent_faq
MILVUS_COLLECTION_MACRO=fin_agent_macro_research
MILVUS_COLLECTION_ANNUAL_REPORT=fin_agent_annual_reports
MILVUS_COLLECTION_RESEARCH_REPORT=fin_agent_research_reports
MILVUS_COLLECTION_INDUSTRY_WHITEPAPER=fin_agent_industry_whitepapers
MILVUS_COLLECTION_POLICY=fin_agent_policy
MILVUS_DIM=1536
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=HNSW
MILVUS_M=16
MILVUS_EF_CONSTRUCTION=200
MILVUS_SEARCH_EF=64
AUTO_MERGE_MIN_CHILDREN=2
# 生产环境开启 xpack.security 后取消注释：
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=

# JWT（W1 Day 3+）
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM（W3+ Supervisor / Agent）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
AGENT_ROUTER_TEMPERATURE=0.0
AGENT_FAQ_TEMPERATURE=0.3
FAQ_MIN_RELEVANCE_SCORE=0.35

# text_to_sql：规则通过后是否启用 LLM 结果质检（默认关闭）
FINANCIAL_SQL_LLM_VALIDATION=false

# text_to_sql：连续相同 validation_error_type 达到此次数后提前结束纠错
FINANCIAL_SQL_MAX_REPEAT_SAME_ERROR=2

# Rerank（文本排序）
RERANK_ENABLED=false
# dashscope | xfyun
RERANK_PROVIDER=dashscope
# 讯飞 MaaS 等独立 rerank 密钥（DashScope 可留空，回退 DASHSCOPE_API_KEY）
RERANK_API_KEY=
RERANK_MODEL=gte-rerank-v2
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_CANDIDATE_TOP_K=20
RERANK_MIN_SCORE=0.7
RERANK_TIMEOUT_SEC=30
RERANK_RETURN_DOCUMENTS=true
PDF_RETRIEVAL_TOP_K=10
PDF_RETRIEVAL_QUALITY_MODEL_PATH=retrieval/models/pdf_retrieval_quality.json

# 讯飞星辰 MaaS Rerank 示例（Qwen3-Reranker-8B）：
# RERANK_ENABLED=true
# RERANK_PROVIDER=xfyun
# RERANK_API_KEY=your_app_id:your_api_secret
# RERANK_MODEL=xop3qwen8breranker
# RERANK_BASE_URL=https://maas-api.cn-huabei-1.xf-yun.com/v2/rerank
