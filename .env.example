# 应用
APP_ENV=development
SECRET_KEY=change-me-in-production

# PostgreSQL（Day 1 下午 docker compose 后启用）
DATABASE_URL=postgresql+asyncpg://fin:fin@localhost:5432/fin_agent

PGVECTOR_DATABASE_URL=postgresql://fin:fin@localhost:5432/fin_agent
LANGGRAPH_CHECKPOINT_URL=postgresql://fin:fin@localhost:5432/fin_agent?options=-csearch_path%3Druntime
EMBEDDING_DIM=1536

# pgvector 集合（LlamaIndex table_name；PG 实际表名为 data_{name}）
PGVECTOR_COLLECTION_FAQ=faq_md_vectors
PGVECTOR_COLLECTION_MACRO=fin_macro_vectors
PGVECTOR_COLLECTION_ANNUAL_REPORT=fin_annual_report_vectors
PGVECTOR_COLLECTION_RESEARCH_REPORT=fin_research_report_vectors
PGVECTOR_COLLECTION_INDUSTRY_WHITEPAPER=fin_industry_whitepaper_vectors
PGVECTOR_COLLECTION_POLICY=fin_policy_vectors

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT（W1 Day 3+）
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM（W3+ Supervisor / Agent）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
AGENT_ROUTER_TEMPERATURE=0.0
AGENT_FAQ_TEMPERATURE=0.3
FAQ_MIN_RELEVANCE_SCORE=0.35

# Embedding（DashScope 兼容 OpenAI API）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v2
